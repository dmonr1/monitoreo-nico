# Entorno de desarrollo local
# Este archivo NO debe subirse a Git.

# DEPLOY puede ser desa o prod.
DEPLOY=desa

# Bases de datos locales de desarrollo.
USERBD=monitoreo
PASSBD=monitoreo123
DB_HOST=localhost
DB_NAME=monitoreo_ti
DB_PORT=5432

# En producción usar variables de entorno del servidor.
# DATABASE_URL sólo se necesita si quieres sobreescribir toda la cadena.
# DATABASE_URL=postgresql://usuario:contraseña@host:5432/monitoreo_ti

SECRET_KEY=cambia-esta-clave-en-produccion
HOST=0.0.0.0
PORT=8000

# CORS: en producción reemplazar con hosts específicos.
CORS_ORIGINS=http://localhost,http://127.0.0.1
